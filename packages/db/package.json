{
  "name": "@repo/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed:sample": "tsx src/seed-sample-cli.ts on --sample",
    "db:seed:clear": "tsx src/seed-sample-cli.ts off --sample",
    "pages:export": "tsx src/export-pages-data.ts",
    "db:import:ideco": "tsx src/import-ideco-csv-cli.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
